<Window x:Class="Trnscrbr.Views.FloatingButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="76"
        Height="58"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid x:Name="Root"
          ClipToBounds="False"
          MouseLeftButtonDown="Root_OnMouseLeftButtonDown"
          MouseLeftButtonUp="Root_OnMouseLeftButtonUp"
          MouseMove="Root_OnMouseMove"
          MouseRightButtonUp="Root_OnMouseRightButtonUp">
        <Ellipse x:Name="GlowHalo"
                 Width="40"
                 Height="34"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Fill="#6636D5D3"
                 Opacity="0.58">
            <Ellipse.Effect>
                <BlurEffect Radius="6" />
            </Ellipse.Effect>
        </Ellipse>
        <Border x:Name="Shell"
                Width="28"
                Height="28"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                BorderBrush="#88FFFFFF"
                Background="#66202834">
            <Grid>
                <StackPanel x:Name="Waveform"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Rectangle x:Name="Bar1" Width="2" Height="6" RadiusX="1" RadiusY="1" Fill="#EFFFFFFF" Margin="0.7" />
                    <Rectangle x:Name="Bar2" Width="2" Height="10" RadiusX="1" RadiusY="1" Fill="#EFFFFFFF" Margin="0.7" />
                    <Rectangle x:Name="Bar3" Width="2" Height="7" RadiusX="1" RadiusY="1" Fill="#EFFFFFFF" Margin="0.7" />
                    <Rectangle x:Name="Bar4" Width="2" Height="12" RadiusX="1" RadiusY="1" Fill="#EFFFFFFF" Margin="0.7" />
                    <Rectangle x:Name="Bar5" Width="2" Height="6" RadiusX="1" RadiusY="1" Fill="#EFFFFFFF" Margin="0.7" />
                </StackPanel>
                <TextBlock x:Name="TimerText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,3"
                           FontSize="7"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Visibility="Collapsed" />
            </Grid>
        </Border>
        <Border x:Name="MessageBubble"
                MaxWidth="210"
                Padding="8,5"
                CornerRadius="8"
                Background="#EE101820"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="Collapsed">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
