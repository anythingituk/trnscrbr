<Window x:Class="Trnscrbr.Views.FloatingButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="118"
        Height="82"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid x:Name="Root"
          ClipToBounds="False"
          MouseLeftButtonDown="Root_OnMouseLeftButtonDown"
          MouseLeftButtonUp="Root_OnMouseLeftButtonUp"
          MouseMove="Root_OnMouseMove"
          MouseRightButtonUp="Root_OnMouseRightButtonUp">
        <Ellipse x:Name="GlowHalo"
                 Width="72"
                 Height="60"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Fill="#6636D5D3"
                 Opacity="0.9">
            <Ellipse.Effect>
                <BlurEffect Radius="14" />
            </Ellipse.Effect>
        </Ellipse>
        <Border x:Name="Shell"
                Width="38"
                Height="38"
                CornerRadius="19"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                BorderBrush="#88FFFFFF"
                Background="#66202834">
            <Grid>
                <StackPanel x:Name="Waveform"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Rectangle x:Name="Bar1" Width="2.5" Height="8" RadiusX="1.25" RadiusY="1.25" Fill="#EFFFFFFF" Margin="1" />
                    <Rectangle x:Name="Bar2" Width="2.5" Height="14" RadiusX="1.25" RadiusY="1.25" Fill="#EFFFFFFF" Margin="1" />
                    <Rectangle x:Name="Bar3" Width="2.5" Height="10" RadiusX="1.25" RadiusY="1.25" Fill="#EFFFFFFF" Margin="1" />
                    <Rectangle x:Name="Bar4" Width="2.5" Height="16" RadiusX="1.25" RadiusY="1.25" Fill="#EFFFFFFF" Margin="1" />
                    <Rectangle x:Name="Bar5" Width="2.5" Height="8" RadiusX="1.25" RadiusY="1.25" Fill="#EFFFFFFF" Margin="1" />
                </StackPanel>
                <TextBlock x:Name="TimerText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,5"
                           FontSize="8"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Visibility="Collapsed" />
            </Grid>
        </Border>
        <Border x:Name="MessageBubble"
                MaxWidth="210"
                Padding="8,5"
                CornerRadius="8"
                Background="#EE101820"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="Collapsed">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
