<Window x:Class="Trnscrbr.Views.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Trnscrbr Settings"
        Width="880"
        Height="740"
        MinWidth="760"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_OnKeyDown">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Trnscrbr Settings" FontSize="24" FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#15202B" Offset="0" />
                            <GradientStop Color="#227C9D" Offset="0.55" />
                            <GradientStop Color="#7C5CFF" Offset="1" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="Configure provider, transcription behaviour, privacy, diagnostics, and packaging support."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource MutedForegroundBrush}" />
                <Border Background="{StaticResource StatusBackgroundBrush}"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Provider" FontWeight="SemiBold" />
                            <TextBlock x:Name="OverviewProviderText"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,14,0">
                            <TextBlock Text="Active engine" FontWeight="SemiBold" />
                            <TextBlock x:Name="OverviewEngineText"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="This month" FontWeight="SemiBold" />
                            <TextBlock x:Name="OverviewUsageText"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <TabControl x:Name="SettingsTabControl" Grid.Row="1" Margin="18">
            <TabItem Header="Setup">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock x:Name="SetupTitleText" Text="Setup" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="SetupIntroText" FontSize="14" Margin="0,8,0,14" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="- Right-click the tray icon or glass button for Settings." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,3" />
                            <TextBlock Text="- Press Ctrl + Alt + R (or F9) to start recording; press it again to stop and transcribe." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,3" />
                            <TextBlock Text="- Hold Ctrl + Alt + Space for push-to-talk, then release to transcribe." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,3" />
                            <TextBlock Text="- Click the glass button for manual recording controls." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,3" />
                            <TextBlock Text="- Press Esc to cancel recording or processing." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,3" />
                            <TextBlock Text="- Use the tray or glass button menu to recover the last transcript for up to one hour." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,3" />
                            <TextBlock Text="- Trnscrbr uses the clipboard temporarily, restores it afterwards, and does not save transcript history." FontSize="14" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox SelectedValue="{Binding Settings.ProviderMode}" SelectedValuePath="Content" Margin="0,0,0,12" SelectionChanged="Settings_OnChanged" AutomationProperties.Name="Provider choice">
                            <ComboBoxItem Content="Not configured" />
                            <ComboBoxItem Content="Bring your own API key" />
                            <ComboBoxItem Content="Local mode" />
                            <ComboBoxItem Content="Cloud managed by app (planned)" IsEnabled="False" />
                        </ComboBox>
                        <TextBlock x:Name="ProviderModeStatusText" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="{StaticResource MutedForegroundBrush}" />
                        <WrapPanel x:Name="SetupActionPanel" Margin="0,0,0,12">
                            <Button x:Name="SetupProviderButton"
                                    Content="Add OpenAI key"
                                    Width="140"
                                    Margin="0,0,8,8"
                                    Click="SetupProvider_OnClick" />
                            <Button x:Name="SetupLocalModelsButton"
                                    Content="Set up local AI"
                                    Width="140"
                                    Margin="0,0,8,8"
                                    Click="SetupLocalModels_OnClick" />
                        </WrapPanel>
                        <Expander Header="Advanced app options" Margin="0,0,0,12">
                            <StackPanel Margin="0,10,0,0">
                                <CheckBox Content="Floating button"
                                          IsChecked="{Binding Settings.FloatingButtonEnabled}"
                                          Margin="0,4"
                                          Click="Settings_OnChanged" />
                                <CheckBox Content="Start with Windows"
                                          IsChecked="{Binding Settings.LaunchOnStartup}"
                                          Margin="0,4"
                                          Click="Settings_OnChanged" />
                                <CheckBox Content="Add trailing space after inserted text"
                                          IsChecked="{Binding Settings.AddTrailingSpace}"
                                          Margin="0,4"
                                          Click="Settings_OnChanged" />
                            </StackPanel>
                        </Expander>
                        <Button x:Name="SetupSkipButton" Content="Decide later" Width="130" HorizontalAlignment="Left" Click="OnboardingComplete_OnClick" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="ProviderTab" Header="Provider">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="OpenAI" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="API keys are stored locally in Windows Credential Manager and are never exported with settings." TextWrapping="Wrap" Margin="0,8,0,12" />
                        <Border x:Name="ApiKeySavedPanel"
                                Background="{StaticResource StatusBackgroundBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="OpenAI key saved" FontWeight="SemiBold" />
                                <TextBlock Text="••••••••••••••••"
                                           FontSize="16"
                                           Foreground="{StaticResource MutedForegroundBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <StackPanel x:Name="ApiKeyEntryPanel" Visibility="Collapsed">
                            <TextBlock Text="Paste a new OpenAI API key" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <PasswordBox x:Name="ApiKeyBox" Height="32" AutomationProperties.Name="OpenAI API key" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="ShowApiKeyEntryButton" Content="Add / Replace Key" Width="145" Click="ShowApiKeyEntry_OnClick" AutomationProperties.Name="Add or replace OpenAI key" />
                            <Button x:Name="TestConnectionButton" Content="Test Connection" Width="130" Margin="8,0,0,0" Click="TestConnection_OnClick" AutomationProperties.Name="Test OpenAI connection" />
                            <Button x:Name="SaveKeyButton" Content="Save Key" Width="100" Margin="8,0,0,0" Click="SaveProvider_OnClick" AutomationProperties.Name="Save OpenAI key" />
                            <Button x:Name="DeleteKeyButton" Content="Delete Key" Width="100" Margin="8,0,0,0" Click="DeleteKey_OnClick" AutomationProperties.Name="Delete OpenAI key" />
                        </StackPanel>
                        <TextBlock x:Name="ApiKeyStatusText" Margin="0,12,0,0" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Margin="0,18,0,0">
                            <Hyperlink NavigateUri="https://platform.openai.com/api-keys" RequestNavigate="Hyperlink_OnRequestNavigate">OpenAI API keys page</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0">
                            <Hyperlink NavigateUri="https://platform.openai.com/docs/quickstart/overview" RequestNavigate="Hyperlink_OnRequestNavigate">OpenAI quickstart</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0">
                            <Hyperlink NavigateUri="https://help.openai.com/en/articles/4936850-where-do-i-find-my-openai-api-key" RequestNavigate="Hyperlink_OnRequestNavigate">Where to find your OpenAI API key</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="LocalModelsTab" Header="Local Models">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Local Mode" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,16" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}"
                                   Text="Local mode is free to use and sends no audio or transcript text to cloud services. Optional cleanup/rewrite can use a local Ollama chat model." />
                        <Border x:Name="LocalReadinessBadge"
                                Background="{StaticResource StatusBackgroundBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16">
                            <TextBlock x:Name="LocalReadinessBadgeText" FontWeight="SemiBold" />
                        </Border>

                        <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Free Quick Setup" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="Downloads the files needed for free local dictation and enables Local mode." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,10" />
                                <WrapPanel>
                                    <Button x:Name="QuickSetupButton" Content="Free Quick Setup" Width="150" Margin="0,0,8,8" Click="QuickSetupLocal_OnClick" />
                                    <Button x:Name="QuickSetupTestPhraseButton" Content="Try Test Phrase" Width="140" Margin="0,0,8,8" Click="RecordLocalTestPhrase_OnClick" />
                                </WrapPanel>
                                <TextBlock x:Name="QuickSetupNextStepText"
                                           Text="After setup, click Try Test Phrase to confirm your microphone and local transcription."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedForegroundBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Local AI model" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="Small is recommended for most PCs. Medium and Large can be much slower." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,10" />
                                <Border Background="{StaticResource StatusBackgroundBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock x:Name="LocalHardwareGuidanceText"
                                                   Text="Checking this PC for local AI guidance..."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedForegroundBrush}" />
                                        <Button Content="Refresh PC Check"
                                                Width="140"
                                                HorizontalAlignment="Left"
                                                Margin="0,8,0,0"
                                                Click="RefreshHardwareGuidance_OnClick" />
                                    </StackPanel>
                                </Border>
                                <ComboBox x:Name="ModelPresetComboBox"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ModelPreset_OnSelectionChanged" />
                                <TextBlock x:Name="ModelPresetDescriptionText"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedForegroundBrush}"
                                           Margin="0,4,0,8" />
                                <WrapPanel Margin="0,0,0,8">
                                    <Button x:Name="DownloadModelButton" Content="Download Model" Width="140" Margin="0,0,8,8" Click="DownloadModel_OnClick" />
                                    <Button x:Name="CancelModelDownloadButton" Content="Cancel Download" Width="140" Margin="0,0,8,8" Click="CancelModelDownload_OnClick" />
                                    <Button x:Name="RemoveModelButton" Content="Remove Model" Width="130" Margin="0,0,8,8" Click="RemoveModel_OnClick" />
                                    <Button Content="Open Folder" Width="120" Margin="0,0,8,8" Click="OpenModelsFolder_OnClick" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Expander Header="Advanced local AI settings" Margin="0,0,0,16">
                            <StackPanel Margin="0,12,0,0">
                                <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,16">
                                    <StackPanel>
                                <TextBlock Text="Installed Components" FontSize="16" FontWeight="SemiBold" />
                                <Grid Margin="0,8,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Local engine" FontWeight="SemiBold" Margin="0,0,12,6" />
                                    <TextBlock x:Name="LocalCliSummaryText" Grid.Column="1" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="1" Text="Model" FontWeight="SemiBold" Margin="0,0,12,6" />
                                    <TextBlock x:Name="LocalModelSummaryText" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="2" Text="Setup" FontWeight="SemiBold" Margin="0,0,12,6" />
                                    <TextBlock x:Name="LocalSetupSummaryText" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="3" Text="Status" FontWeight="SemiBold" Margin="0,0,12,0" />
                                    <TextBlock x:Name="LocalModeStatusText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}" />
                                </Grid>
                                <WrapPanel>
                                    <Button x:Name="CheckWhisperCliUpdateButton" Content="Check Update" Width="150" Margin="0,0,8,8" Click="CheckWhisperCliUpdate_OnClick" />
                                    <Button x:Name="VerifyModelButton" Content="Verify Model" Width="130" Margin="0,0,8,8" Click="VerifyModel_OnClick" />
                                    <Button x:Name="UseLocalModeButton" Content="Use Local Mode" Width="140" Margin="0,0,8,8" Click="SaveLocalMode_OnClick" />
                                    <Button x:Name="RepairLocalModeButton" Content="Complete Setup" Width="150" Margin="0,0,8,8" Click="RepairLocalMode_OnClick" />
                                    <Button x:Name="CancelLocalRepairButton" Content="Cancel Setup" Width="130" Margin="0,0,8,8" Click="CancelModelDownload_OnClick" />
                                </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,16">
                                    <StackPanel>
                                <TextBlock Text="Manual Setup" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="Local engine executable" FontWeight="SemiBold" Margin="0,10,0,6" />
                                <WrapPanel Margin="0,0,0,8">
                                    <Button x:Name="InstallWhisperCliButton" Content="Install Local Engine" Width="150" Margin="0,0,8,8" Click="InstallWhisperCli_OnClick" />
                                    <Button Content="Open Tools Folder" Width="150" Margin="0,0,8,8" Click="OpenWhisperToolsFolder_OnClick" />
                                </WrapPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding Settings.LocalWhisperExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button x:Name="BrowseWhisperExecutableButton" Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="BrowseWhisperExecutable_OnClick" />
                                </Grid>
                                <TextBlock Text="Example: C:\Tools\LocalAI\local-engine.exe" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,10" />

                                <TextBlock Text="Local AI model" FontWeight="SemiBold" Margin="0,6,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding Settings.LocalWhisperModelPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button x:Name="BrowseWhisperModelButton" Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="BrowseWhisperModel_OnClick" />
                                </Grid>
                                <TextBlock Text="Example: C:\Models\ggml-small.en.bin" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,10" />
                                <CheckBox Content="Force CPU-only mode" IsChecked="{Binding Settings.ForceCpuOnly}" Margin="0,6,0,0" Click="Settings_OnChanged" />
                                    </StackPanel>
                                </Border>

                                <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,16">
                                    <StackPanel>
                                <TextBlock Text="Tests" FontSize="16" FontWeight="SemiBold" />
                                <WrapPanel Margin="0,10,0,8">
                                    <Button x:Name="TestLocalSetupButton" Content="Test Local Setup" Width="140" Margin="0,0,8,8" Click="TestLocalSetup_OnClick" />
                                    <Button x:Name="RunSmokeTestButton" Content="Run Smoke Test" Width="140" Margin="0,0,8,8" Click="RunLocalSmokeTest_OnClick" />
                                    <Button x:Name="RecordTestPhraseButton" Content="Record Test Phrase" Width="155" Margin="0,0,8,8" Click="RecordLocalTestPhrase_OnClick" />
                                    <Button x:Name="DetectLocalModelsButton" Content="Detect Local Models" Width="150" Margin="0,0,8,8" Click="DetectLocalModels_OnClick" />
                                </WrapPanel>
                                <TextBlock x:Name="LocalTestStatusText"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Local test transcript" FontWeight="SemiBold" Margin="0,10,0,6" />
                                <TextBox x:Name="LocalTestTranscriptBox"
                                         IsReadOnly="True"
                                         MinHeight="72"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Text="Detected models are suggestions. Paste the executable and model path above to enable local dictation." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,10,0,8" />
                                <TextBox x:Name="LocalModelsBox" IsReadOnly="True" MinHeight="120" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Border>

                                <StackPanel>
                            <TextBlock Text="Optional Ollama Cleanup" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Ollama cleanup endpoint" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <TextBox Text="{Binding Settings.LocalLlmEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Default: http://localhost:11434/api/chat" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,10" />
                            <TextBlock Text="Ollama cleanup model" FontWeight="SemiBold" Margin="0,6,0,6" />
                            <TextBox Text="{Binding Settings.LocalLlmModel, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Leave blank to insert the raw local AI transcript without cleanup." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,4,0,10" />
                            <Button x:Name="DetectOllamaModelsButton" Content="Detect Ollama Models" Width="160" HorizontalAlignment="Left" Margin="0,4,0,0" Click="DetectOllamaModels_OnClick" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Privacy &amp; Context">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Transcription type" FontWeight="SemiBold" />
                        <ComboBox SelectedValue="{Binding Settings.CleanupMode}" SelectedValuePath="Content" Margin="0,6,0,14" SelectionChanged="Settings_OnChanged">
                            <ComboBoxItem Content="Clean only" />
                            <ComboBoxItem Content="Rewrite" />
                        </ComboBox>
                        <StackPanel Margin="0,0,0,14">
                            <StackPanel.Style>
                                <Style TargetType="{x:Type StackPanel}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.CleanupMode}" Value="Rewrite">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Rewrite style" FontWeight="SemiBold" />
                            <ComboBox SelectedValue="{Binding Settings.RewriteStyle}" SelectedValuePath="Content" Margin="0,6,0,8" SelectionChanged="Settings_OnChanged">
                                <ComboBoxItem Content="Plain English" />
                                <ComboBoxItem Content="Professional" />
                                <ComboBoxItem Content="Friendly" />
                                <ComboBoxItem Content="Concise" />
                                <ComboBoxItem Content="Native-level English" />
                            </ComboBox>
                            <TextBlock Text="Rewrite style is used only when transcription type is set to Rewrite." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                        </StackPanel>
                        <CheckBox Content="Contextual correction" IsChecked="{Binding Settings.ContextualCorrectionEnabled}" Margin="0,4" Click="Settings_OnChanged" />
                        <CheckBox Content="Use text around cursor as context" IsChecked="{Binding Settings.CursorContextEnabled}" Margin="0,4" Click="CursorContext_OnClick" />
                        <TextBlock Text="Reading text around the cursor may expose nearby content from another app and may be unreliable depending on the target application." TextWrapping="Wrap" Margin="24,4,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="Paste method" FontWeight="SemiBold" Margin="0,14,0,6" />
                        <ComboBox SelectedValue="{Binding Settings.PasteMethod}" SelectedValuePath="Content" SelectionChanged="Settings_OnChanged">
                            <ComboBoxItem Content="Ctrl+V" />
                            <ComboBoxItem Content="Shift+Insert" />
                        </ComboBox>
                        <TextBlock Text="Use Shift+Insert only for target apps that do not respond reliably to Ctrl+V." TextWrapping="Wrap" Margin="0,6,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="Capture startup buffer" FontWeight="SemiBold" Margin="0,14,0,6" />
                        <ComboBox SelectedValue="{Binding Settings.CaptureStartupBufferMilliseconds}" SelectedValuePath="Tag" SelectionChanged="CaptureBuffer_OnSelectionChanged">
                            <ComboBoxItem Content="Off">
                                <ComboBoxItem.Tag>
                                    <sys:Int32>0</sys:Int32>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="250ms">
                                <ComboBoxItem.Tag>
                                    <sys:Int32>250</sys:Int32>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="500ms">
                                <ComboBoxItem.Tag>
                                    <sys:Int32>500</sys:Int32>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="750ms">
                                <ComboBoxItem.Tag>
                                    <sys:Int32>750</sys:Int32>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                        </ComboBox>
                        <TextBlock Text="Keeps a short in-memory audio buffer while the app is running so the first word is less likely to be clipped. Audio is not saved unless recording starts." TextWrapping="Wrap" Margin="0,6,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="Language" FontWeight="SemiBold" Margin="0,14,0,6" />
                        <ComboBox SelectedValue="{Binding Settings.LanguageMode}" SelectedValuePath="Tag" SelectionChanged="Settings_OnChanged">
                            <ComboBoxItem Content="Auto detect">
                                <ComboBoxItem.Tag>
                                    <sys:String>Auto</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="English">
                                <ComboBoxItem.Tag>
                                    <sys:String>en</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="French">
                                <ComboBoxItem.Tag>
                                    <sys:String>fr</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="Spanish">
                                <ComboBoxItem.Tag>
                                    <sys:String>es</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="German">
                                <ComboBoxItem.Tag>
                                    <sys:String>de</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="Italian">
                                <ComboBoxItem.Tag>
                                    <sys:String>it</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="Portuguese">
                                <ComboBoxItem.Tag>
                                    <sys:String>pt</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="Dutch">
                                <ComboBoxItem.Tag>
                                    <sys:String>nl</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                            <ComboBoxItem Content="Polish">
                                <ComboBoxItem.Tag>
                                    <sys:String>pl</sys:String>
                                </ComboBoxItem.Tag>
                            </ComboBoxItem>
                        </ComboBox>
                        <TextBlock Text="Auto detect is recommended unless recognition repeatedly chooses the wrong language." TextWrapping="Wrap" Margin="0,6,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="English spelling" FontWeight="SemiBold" Margin="0,14,0,6" />
                        <ComboBox SelectedValue="{Binding Settings.EnglishDialect}" SelectedValuePath="Content" SelectionChanged="Settings_OnChanged">
                            <ComboBoxItem Content="Auto" />
                            <ComboBoxItem Content="British English" />
                            <ComboBoxItem Content="American English" />
                            <ComboBoxItem Content="Canadian English" />
                            <ComboBoxItem Content="Australian English" />
                        </ComboBox>
                        <TextBlock Text="Auto uses your Windows region to choose the English spelling convention for cleanup and rewrite." TextWrapping="Wrap" Margin="0,6,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <CheckBox Content="Voice action commands" IsChecked="{Binding Settings.VoiceActionCommandsEnabled}" Margin="0,4" Click="Settings_OnChanged" />
                        <CheckBox Content="Anonymous diagnostics" IsChecked="{Binding Settings.DiagnosticsEnabled}" Margin="0,4" Click="Settings_OnChanged" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Hotkeys">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Hotkeys" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Use toggle recording for normal dictation, or hold push-to-talk while speaking and release to transcribe." TextWrapping="Wrap" Margin="0,8,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <CheckBox Content="Enable global hotkeys" IsChecked="{Binding Settings.GlobalHotkeysEnabled}" Margin="0,0,0,14" Click="Settings_OnChanged" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Toggle recording" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <ComboBox x:Name="ToggleHotkeyComboBox" Grid.Column="1" SelectedValue="{Binding Settings.ToggleRecordingHotkey}" SelectedValuePath="Content" Margin="0,0,0,8" SelectionChanged="Settings_OnChanged">
                                <ComboBoxItem Content="Ctrl+Alt+R" />
                                <ComboBoxItem Content="Ctrl+Shift+R" />
                                <ComboBoxItem Content="Ctrl+Alt+D" />
                                <ComboBoxItem Content="F9" />
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="Push-to-talk" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <ComboBox x:Name="PushToTalkHotkeyComboBox" Grid.Row="1" Grid.Column="1" SelectedValue="{Binding Settings.PushToTalkHotkey}" SelectedValuePath="Content" Margin="0,0,0,8" SelectionChanged="Settings_OnChanged">
                                <ComboBoxItem Content="Ctrl+Alt+Space" />
                                <ComboBoxItem Content="Ctrl+Shift+Space" />
                                <ComboBoxItem Content="F10" />
                            </ComboBox>
                            <TextBlock Grid.Row="2" Text="Cancel" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Esc" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="3" Text="Paste Last Transcript" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Tray/glass button menu" Margin="0,0,0,8" />
                        </Grid>
                        <TextBlock x:Name="HotkeyStatusText"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="A global paste-last-transcript shortcut is disabled for now to avoid collisions with Windows clipboard and accessibility shortcuts." TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource MutedForegroundBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Vocabulary">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Vocabulary" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Add words Trnscrbr may not know, such as names, product names, acronyms, client names, or specialist terms. During cleanup, Trnscrbr uses this list as spelling hints so dictated text is less likely to be corrected to a similar common word." TextWrapping="Wrap" Margin="0,8,0,6" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="Put one word or phrase on each line so each item is treated as a separate hint. Example lines: Trnscrbr, HyperX QuadCast, Inno Setup." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                    </StackPanel>
                    <TextBox x:Name="VocabularyBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
            <TabItem Header="Diagnostics">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Diagnostics never include transcript text, raw audio, or API keys." TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,18">
                            <Button Content="Copy Diagnostics" Width="150" Click="CopyDiagnostics_OnClick" />
                            <Button Content="Refresh Log" Width="110" Margin="8,0,0,0" Click="RefreshDiagnostics_OnClick" />
                            <Button Content="Open Folder" Width="110" Margin="8,0,0,0" Click="OpenDiagnosticsFolder_OnClick" />
                        </StackPanel>
                        <TextBox x:Name="DiagnosticsBox" IsReadOnly="True" MinHeight="260" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Usage">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Usage" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Metadata only. Transcript text and raw audio are not stored." TextWrapping="Wrap" Margin="0,8,0,12" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="Monthly cost warning (USD)" FontWeight="SemiBold" />
                        <TextBox x:Name="MonthlyWarningBox" Text="{Binding Settings.MonthlyCostWarning}" Width="120" HorizontalAlignment="Left" Margin="0,6,0,12" LostFocus="MonthlyWarning_OnLostFocus" />
                        <TextBlock Text="Estimates are shown in provider billing currency and may differ from official billing." TextWrapping="Wrap" Margin="0,0,0,12" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Margin="0,0,0,12">
                            <Hyperlink NavigateUri="https://platform.openai.com/usage" RequestNavigate="Hyperlink_OnRequestNavigate">OpenAI Usage Dashboard</Hyperlink>
                        </TextBlock>
                        <Button Content="Refresh Usage" Width="130" HorizontalAlignment="Left" Margin="0,0,0,12" Click="RefreshUsage_OnClick" />
                        <TextBox x:Name="UsageBox" IsReadOnly="True" MinHeight="320" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Updates">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Updates" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentVersionText" Margin="0,8,0,12" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Text="Trnscrbr checks GitHub releases and opens the installer download when an update is available." TextWrapping="Wrap" Margin="0,0,0,12" />
                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Check for Updates" Width="150" Margin="0,0,8,8" Click="CheckUpdates_OnClick" />
                            <Button x:Name="OpenLatestReleaseButton"
                                    Content="Open Download"
                                    Width="160"
                                    Margin="0,0,8,8"
                                    Click="OpenLatestRelease_OnClick" />
                        </WrapPanel>
                        <TextBlock x:Name="UpdateStatusText" TextWrapping="Wrap" Margin="0,0,0,12" Foreground="{StaticResource MutedForegroundBrush}" />
                        <TextBlock Margin="0,0,0,12">
                            <Hyperlink NavigateUri="https://github.com/anythingituk/trnscrbr/releases" RequestNavigate="Hyperlink_OnRequestNavigate">Open Trnscrbr releases</Hyperlink>
                        </TextBlock>
                        <TextBlock Text="Automatic installation is planned for a later version. For now, download and run the installer from the release page." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Import/Export">
                <ScrollViewer>
                    <StackPanel Margin="18">
                        <TextBlock Text="Import / Export" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Exports include settings and custom vocabulary only. API keys, transcripts, raw audio, diagnostics, and usage history are never exported." TextWrapping="Wrap" Margin="0,8,0,14" Foreground="{StaticResource MutedForegroundBrush}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Export Settings" Width="130" Click="ExportSettings_OnClick" />
                            <Button Content="Import Settings" Width="130" Margin="8,0,0,0" Click="ImportSettings_OnClick" />
                        </StackPanel>
                        <TextBlock x:Name="ImportExportStatusText" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
