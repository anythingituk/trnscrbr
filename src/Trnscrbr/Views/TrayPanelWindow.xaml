<Window x:Class="Trnscrbr.Views.TrayPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380"
        Height="570"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Margin="12"
            Padding="18"
            CornerRadius="10"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="#22000000"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#66000000" BlurRadius="24" ShadowDepth="2" Opacity="0.35" />
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Trnscrbr" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PanelForegroundBrush}" />
            <TextBlock Text="{Binding StatusMessage}" Margin="0,4,0,18" Foreground="{StaticResource MutedForegroundBrush}" />
            <Button x:Name="RecordButton" Content="Start Recording" Height="34" Margin="0,0,0,18" Click="Record_OnClick" />

            <TextBlock Text="Provider" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Settings.ProviderMode}" Margin="0,3,0,12" Foreground="{StaticResource MutedForegroundBrush}" />

            <TextBlock Text="Active Engine" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ActiveEngineLabel}" Margin="0,3,0,12" Foreground="{StaticResource MutedForegroundBrush}" />

            <TextBlock Text="Shortcuts" FontWeight="SemiBold" />
            <TextBlock Text="Dictate: Ctrl + Win + Space | Paste: Ctrl + Win + V" Margin="0,3,0,12" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />

            <TextBlock Text="Paste Method" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Settings.PasteMethod}" Margin="0,3,0,12" Foreground="{StaticResource MutedForegroundBrush}" />

            <TextBlock Text="Transcription Type" FontWeight="SemiBold" />
            <ComboBox SelectedValue="{Binding Settings.CleanupMode}" SelectedValuePath="Content" Margin="0,6,0,14" SelectionChanged="Settings_OnChanged">
                <ComboBoxItem Content="Clean only" />
                <ComboBoxItem Content="Rewrite" />
            </ComboBox>

            <TextBlock Text="Rewrite Style" FontWeight="SemiBold" />
            <ComboBox SelectedValue="{Binding Settings.RewriteStyle}" SelectedValuePath="Content" Margin="0,6,0,14" SelectionChanged="Settings_OnChanged">
                <ComboBoxItem Content="Plain English" />
                <ComboBoxItem Content="Professional" />
                <ComboBoxItem Content="Friendly" />
                <ComboBoxItem Content="Concise" />
                <ComboBoxItem Content="Native-level English" />
            </ComboBox>

            <TextBlock Text="Microphone" FontWeight="SemiBold" />
            <ComboBox x:Name="MicrophoneBox"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      Margin="0,6,0,14"
                      SelectionChanged="Microphone_OnSelectionChanged" />

            <CheckBox Content="Show floating button" IsChecked="{Binding Settings.FloatingButtonEnabled}" Margin="0,4" Click="FloatingButton_OnClick" />
            <CheckBox Content="Launch on Windows startup" IsChecked="{Binding Settings.LaunchOnStartup}" Margin="0,4" Click="Settings_OnChanged" />
            <CheckBox Content="Add trailing space" IsChecked="{Binding Settings.AddTrailingSpace}" Margin="0,4" Click="Settings_OnChanged" />

            <Button Content="Advanced Settings" Margin="0,22,0,0" Height="36" Click="Advanced_OnClick" />
        </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
