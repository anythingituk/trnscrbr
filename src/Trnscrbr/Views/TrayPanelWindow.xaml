<Window x:Class="Trnscrbr.Views.TrayPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="410"
        Height="545"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        KeyDown="Window_OnKeyDown">
    <Border Margin="12"
            Padding="20"
            CornerRadius="14"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#66000000" BlurRadius="28" ShadowDepth="4" Opacity="0.25" />
        </Border.Effect>
        <StackPanel>
            <DockPanel Margin="0,0,0,8" LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Advanced_OnClick"
                        ToolTip="Advanced Settings">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Chrome" Background="Transparent" CornerRadius="16">
                                <TextBlock Text="⚙"
                                           FontSize="18"
                                           FontFamily="Segoe UI Symbol"
                                           Foreground="{StaticResource PanelForegroundBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="24" Height="24" Margin="0,0,8,0" SnapsToDevicePixels="True">
                        <Ellipse Width="23" Height="23" Opacity="0.52">
                            <Ellipse.Fill>
                                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.42,0.36" RadiusX="0.62" RadiusY="0.62">
                                    <GradientStop Color="#8846FFF0" Offset="0" />
                                    <GradientStop Color="#3364E6C8" Offset="0.58" />
                                    <GradientStop Color="#0036D5D3" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="18" Height="18">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#46FFF0" Offset="0" />
                                    <GradientStop Color="#2396BE" Offset="0.58" />
                                    <GradientStop Color="#8C70FF" Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="17" Height="17" Stroke="#AAFFFFFF" StrokeThickness="1.3" />
                        <Ellipse Width="5.5" Height="4" Fill="#DDFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6.5,4.5,0,0" />
                    </Grid>
                    <TextBlock Text="Trnscrbr" FontSize="24" FontWeight="SemiBold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#15202B" Offset="0" />
                                <GradientStop Color="#227C9D" Offset="0.55" />
                                <GradientStop Color="#7C5CFF" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
            <DockPanel Margin="0,0,0,12" LastChildFill="True">
                <Button x:Name="RecordButton"
                        DockPanel.Dock="Right"
                        Width="36"
                        Height="36"
                        Padding="0"
                        Margin="10,0,0,0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Record_OnClick"
                        ToolTip="Start Recording">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    Background="Transparent"
                                    CornerRadius="18">
                                <Grid>
                                    <Ellipse x:Name="OuterRing" Fill="#F31212" />
                                    <Ellipse x:Name="InnerCutout" Width="24" Height="24" Fill="{StaticResource SurfaceBrush}" />
                                    <Ellipse x:Name="RecordGlyph" Width="18" Height="18" Fill="#F31212" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OuterRing" Property="Fill" Value="#D90D0D" />
                                    <Setter TargetName="RecordGlyph" Property="Fill" Value="#D90D0D" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="OuterRing" Property="Fill" Value="#B80808" />
                                    <Setter TargetName="RecordGlyph" Property="Fill" Value="#B80808" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Border Background="{StaticResource StatusBackgroundBrush}" CornerRadius="8" Padding="10,7" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                </Border>
            </DockPanel>

            <TextBlock Margin="0,0,0,6">
                <Run Text="Provider" FontWeight="SemiBold" />
                <Run Text=" " />
                <Run Text="{Binding Settings.ProviderMode}" Foreground="{StaticResource MutedForegroundBrush}" />
            </TextBlock>
            <TextBlock Margin="0,0,0,10">
                <Run Text="Active engine" FontWeight="SemiBold" />
                <Run Text=" " />
                <Run Text="{Binding ActiveEngineLabel}" Foreground="{StaticResource MutedForegroundBrush}" />
            </TextBlock>
            <Border x:Name="UsageBadge" Background="{StaticResource AccentSoftBrush}" CornerRadius="7" Padding="9,6" Margin="0,0,0,12">
                <TextBlock x:Name="UsageText" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
            </Border>

            <TextBlock Text="Transcription Type" FontWeight="SemiBold" />
            <ComboBox SelectedValue="{Binding Settings.CleanupMode}" SelectedValuePath="Content" Margin="0,6,0,12" SelectionChanged="Settings_OnChanged">
                <ComboBoxItem Content="Clean only" />
                <ComboBoxItem Content="Rewrite" />
            </ComboBox>

            <StackPanel Margin="0,0,0,12">
                <StackPanel.Style>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.CleanupMode}" Value="Rewrite">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Rewrite Style" FontWeight="SemiBold" />
                <ComboBox SelectedValue="{Binding Settings.RewriteStyle}" SelectedValuePath="Content" Margin="0,6,0,0" SelectionChanged="Settings_OnChanged">
                    <ComboBoxItem Content="Plain English" />
                    <ComboBoxItem Content="Professional" />
                    <ComboBoxItem Content="Friendly" />
                    <ComboBoxItem Content="Concise" />
                    <ComboBoxItem Content="Native-level English" />
                </ComboBox>
            </StackPanel>

            <TextBlock Text="Microphone" FontWeight="SemiBold" />
            <ComboBox x:Name="MicrophoneBox"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      Margin="0,6,0,12"
                      SelectionChanged="Microphone_OnSelectionChanged" />

            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <CheckBox Content="Floating button"
                              IsChecked="{Binding Settings.FloatingButtonEnabled}"
                              Margin="0,3"
                              Click="FloatingButton_OnClick" />
                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding Settings.LaunchOnStartup}"
                              Margin="0,3"
                              Click="Settings_OnChanged" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <CheckBox Content="Trailing space"
                              IsChecked="{Binding Settings.AddTrailingSpace}"
                              Margin="0,3"
                              Click="Settings_OnChanged" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
