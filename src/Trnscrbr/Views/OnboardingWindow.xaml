<Window x:Class="Trnscrbr.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Trnscrbr"
        Width="520"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="18"
            Padding="24"
            CornerRadius="14"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Trnscrbr" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Dictate into the focused text field, review the inserted text, then send it yourself."
                       Margin="0,6,0,18"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedForegroundBrush}" />

            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Hold Ctrl + Win + Space to record, then release to transcribe." TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock Text="Trnscrbr inserts text for review and never presses Enter." TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock Text="The tray icon and glass button open recording controls and settings." TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock Text="Cloud/API modes may use third-party services. Local mode is planned and requires model downloads." TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock Text="Text is pasted through the clipboard temporarily, then the previous clipboard is restored." TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="{StaticResource StatusBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,18">
                <TextBlock Text="Bring your own OpenAI API key is available now. You can skip setup and configure it later from the tray."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AccentBrush}" />
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Skip for now" Width="120" Margin="0,0,8,0" Click="Skip_OnClick" />
                <Button Content="Set up provider" Width="140" Click="Setup_OnClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
