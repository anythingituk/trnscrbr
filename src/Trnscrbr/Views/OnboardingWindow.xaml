<Window x:Class="Trnscrbr.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Trnscrbr"
        Width="560"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="18"
            Padding="24"
            CornerRadius="14"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Trnscrbr" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Free local dictation first. Cloud/API options stay available in Advanced Settings."
                       Margin="0,6,0,18"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedForegroundBrush}" />

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="1" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,12" />
                <StackPanel Grid.Column="1" Margin="0,0,0,12">
                    <TextBlock Text="Run Free Quick Setup" FontWeight="SemiBold" />
                    <TextBlock Text="Trnscrbr installs the official local Whisper tools and a verified model." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                </StackPanel>
                <TextBlock Grid.Row="1" Text="2" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,12" />
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                    <TextBlock Text="Try a test phrase" FontWeight="SemiBold" />
                    <TextBlock Text="Confirm your microphone and local transcription before using it in another app." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                </StackPanel>
                <TextBlock Grid.Row="2" Text="3" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                <StackPanel Grid.Row="2" Grid.Column="1">
                    <TextBlock Text="Start dictating" FontWeight="SemiBold" />
                    <TextBlock Text="Press Ctrl + Alt + R to start and stop recording. Trnscrbr pastes text for review and never presses Enter." TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" />
                </StackPanel>
            </Grid>

            <Border Background="{StaticResource StatusBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,18">
                <TextBlock Text="You can skip setup and configure free local mode later from the tray. Text is pasted through the clipboard temporarily, then the previous clipboard is restored."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AccentBrush}" />
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Skip for now" Width="120" Margin="0,0,8,0" Click="Skip_OnClick" />
                <Button Content="Set up free local mode" Width="170" Click="Setup_OnClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
