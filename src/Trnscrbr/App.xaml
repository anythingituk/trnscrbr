<Application x:Class="Trnscrbr.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="GlassBackgroundColor">#66202834</Color>
            <SolidColorBrush x:Key="GlassBackgroundBrush" Color="{StaticResource GlassBackgroundColor}" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F7FAFC" />
            <SolidColorBrush x:Key="PanelForegroundBrush" Color="#15202B" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#617080" />
            <SolidColorBrush x:Key="AccentBrush" Color="#227C9D" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
